        <mass value="0.40"/>

        <inertia
            ixx="0.0018"
            iyy="0.0018"
            izz="0.0053"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>
<!-- ===================================== -->
<!-- Middle Plate -> Top Plate             -->
<!-- ===================================== -->

<joint name="middle_to_top_plate_joint"
       type="fixed">

    <parent link="middle_plate_link"/>

    <child link="top_plate_link"/>

    <!--
        Middle plate thickness = 8 mm
        Upper pillar height = 80 mm
        Top plate thickness = 8 mm

        0.004 + 0.080 + 0.004 = 0.088
    -->

    <origin xyz="0 0 0.088"
            rpy="0 0 0"/>

</joint>
<!-- ===================================== -->
<!-- RPLIDAR                               -->
<!-- ===================================== -->

<link name="lidar_link">

    <!-- Visual -->
    <visual>

        <geometry>
            <cylinder radius="0.035"
                      length="0.040"/>
        </geometry>

        <material name="lidar_black">
            <color rgba="0.15 0.15 0.15 1"/>
        </material>

    </visual>

    <!-- Collision -->
    <collision>

        <geometry>
            <cylinder radius="0.035"
                      length="0.040"/>
        </geometry>

    </collision>

    <!-- Inertial -->
    <inertial>

        <origin xyz="0 0 0"/>

        <mass value="0.17"/>

        <inertia
            ixx="0.000071"
            iyy="0.000071"
            izz="0.000104"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>
<!-- ===================================== -->
<!-- Top Plate -> LiDAR                    -->
<!-- ===================================== -->
<joint name="top_plate_to_lidar_joint"
       type="fixed">

    <parent link="top_plate_link"/>

    <child link="lidar_link"/>

    <!-- Slightly towards caster -->
    <origin xyz="-0.05 0 0.024"
            rpy="0 0 0"/>

</joint>
<!-- ===================================== -->
<!-- Gazebo LiDAR                          -->
<!-- ===================================== -->

<gazebo reference="lidar_link">

    <sensor name="lidar_sensor"
            type="ray">

        <always_on>true</always_on>

        <visualize>true</visualize>

        <update_rate>10</update_rate>

        <pose>0 0 0 0 0 0</pose>

        <ray>

            <scan>

                <horizontal>

                    <samples>720</samples>

                    <resolution>1</resolution>

                    <min_angle>-3.14159</min_angle>

                    <max_angle>3.14159</max_angle>

                </horizontal>

            </scan>

            <range>

                <min>0.12</min>

                <max>12.0</max>

                <resolution>0.01</resolution>

            </range>

        </ray>

        <plugin
            name="gazebo_ros_laser"
            filename="libgazebo_ros_ray_sensor.so">

            <ros>

                <remapping>~/out:=scan</remapping>

            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>lidar_link</frame_name>

        </plugin>

    </sensor>

</gazebo>

<!-- ===================================== -->
<!-- Gazebo Properties                     -->
<!-- ===================================== -->

<gazebo reference="left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
</gazebo>

<gazebo reference="right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
</gazebo>

<gazebo reference="caster_wheel_link">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
</gazebo>

<!-- ===================================== -->
<!-- ros2_control                          -->
<!-- ===================================== -->

<ros2_control name="ServingRobotSystem" type="system">

    <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
    </joint>

</ros2_control>

<gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>ROS2_CONTROLLERS_YAML_PATH</parameters>
    </plugin>
</gazebo>

</robot>