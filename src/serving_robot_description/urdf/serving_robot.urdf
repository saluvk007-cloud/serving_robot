<?xml version="1.0"?>

<robot name="serving_robot">

    <!-- ===================================== -->
<!-- Robot Reference Frame                 -->
<!-- ===================================== -->

<link name="base_link"/>
<!-- ===================================== -->
<!-- Bottom Plate                          -->
<!-- ===================================== -->

<link name="bottom_plate_link">

    <!-- Visual -->
    <visual>

        <origin xyz="0 0 0"
                rpy="0 0 0"/>

        <geometry>

            <cylinder radius="0.16"
                      length="0.008"/>

        </geometry>

        <material name="blue">

            <color rgba="0.2 0.4 0.9 1"/>

        </material>

    </visual>

    <!-- Collision -->
    <collision>

        <origin xyz="0 0 0"
                rpy="0 0 0"/>

        <geometry>

            <cylinder radius="0.16"
                      length="0.008"/>

        </geometry>

    </collision>

    <!-- Inertial -->
    <inertial>

        <origin xyz="0 0 0"/>

        <mass value="0.60"/>

        <inertia
            ixx="0.0026"
            iyy="0.0026"
            izz="0.0077"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>
<!-- ===================================== -->
<!-- Base -> Bottom Plate                  -->
<!-- ===================================== -->

<joint name="base_to_bottom_plate"
       type="fixed">

    <parent link="base_link"/>

    <child link="bottom_plate_link"/>

    <origin xyz="0 0 0.044"
            rpy="0 0 0"/>

</joint>

<!-- ========================= -->
<!-- Left Wheel               -->
<!-- ========================= -->

<link name="left_wheel_link">

    <visual>

        <origin xyz="0 0 0"
                rpy="1.5708 0 0"/>

        <geometry>

            <cylinder radius="0.04"
                      length="0.03"/>

        </geometry>

        <material name="black">

            <color rgba="0.1 0.1 0.1 1"/>

        </material>

    </visual>

    <collision>

        <origin xyz="0 0 0"
                rpy="1.5708 0 0"/>

        <geometry>

            <cylinder radius="0.04"
                      length="0.03"/>

        </geometry>

    </collision>

    <inertial>

        <origin xyz="0 0 0"/>

        <mass value="0.20"/>

        <inertia
            ixx="0.00011"
            iyy="0.00011"
            izz="0.00016"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>

<joint name="left_wheel_joint"
       type="continuous">

    <parent link="bottom_plate_link"/>

    <child link="left_wheel_link"/>

    <origin xyz="0.03 0.14 -0.04"
            rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

</joint>

<!-- ========================= -->
<!-- Right Wheel              -->
<!-- ========================= -->

<link name="right_wheel_link">

    <visual>

        <origin xyz="0 0 0"
                rpy="1.5708 0 0"/>

        <geometry>

            <cylinder radius="0.04"
                      length="0.03"/>

        </geometry>

        <material name="black">

            <color rgba="0.1 0.1 0.1 1"/>

        </material>

    </visual>

    <collision>

        <origin xyz="0 0 0"
                rpy="1.5708 0 0"/>

        <geometry>

            <cylinder radius="0.04"
                      length="0.03"/>

        </geometry>

    </collision>

    <inertial>

        <origin xyz="0 0 0"/>

        <mass value="0.20"/>

        <inertia
            ixx="0.00011"
            iyy="0.00011"
            izz="0.00016"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>

<joint name="right_wheel_joint"
       type="continuous">

    <parent link="bottom_plate_link"/>

    <child link="right_wheel_link"/>

    <origin xyz="0.03 -0.14 -0.04"
            rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

</joint>
<!-- ===================================== -->
<!-- Caster Mount                          -->
<!-- ===================================== -->

<link name="caster_mount_link">

    <visual>

        <origin xyz="0 0 0"/>

        <geometry>
            <box size="0.05 0.04 0.03"/>
        </geometry>

        <material name="dark_gray">
            <color rgba="0.25 0.25 0.25 1"/>
        </material>

    </visual>

    <collision>

        <origin xyz="0 0 0"/>

        <geometry>
            <box size="0.05 0.04 0.03"/>
        </geometry>

    </collision>

    <inertial>

        <origin xyz="0 0 0"/>

        <mass value="0.05"/>

        <inertia
            ixx="0.00002"
            iyy="0.00002"
            izz="0.00002"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>
<joint name="bottom_to_caster_mount_joint"
       type="fixed">

    <parent link="bottom_plate_link"/>

    <child link="caster_mount_link"/>

    <origin xyz="-0.12 0 -0.019"
            rpy="0 0 0"/>

</joint>
<!-- ===================================== -->
<!-- Caster Wheel                          -->
<!-- ===================================== -->

<link name="caster_wheel_link">

    <visual>

        <geometry>
            <sphere radius="0.025"/>
