        <material name="gray">
            <color rgba="0.7 0.7 0.7 1"/>
        </material>

    </visual>

    <collision>

        <geometry>
            <sphere radius="0.025"/>
        </geometry>

    </collision>

    <inertial>

        <mass value="0.08"/>

        <origin xyz="0 0 0"/>

        <inertia
            ixx="0.00002"
            iyy="0.00002"
            izz="0.00002"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>

<joint name="caster_wheel_joint"
       type="continuous">

    <parent link="caster_mount_link"/>

    <child link="caster_wheel_link"/>

    <origin xyz="0 0 -0.040"
            rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

</joint>
