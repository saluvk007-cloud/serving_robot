<!-- Battery Pack                          -->
<!-- ===================================== -->

<link name="battery_link">

    <visual>

        <geometry>
            <box size="0.070 0.060 0.020"/>
        </geometry>

        <material name="battery_black">
            <color rgba="0.15 0.15 0.15 1"/>
        </material>

    </visual>

    <collision>

        <geometry>
            <box size="0.070 0.060 0.020"/>
        </geometry>

    </collision>

    <inertial>

        <origin xyz="0 0 0"/>

        <mass value="0.25"/>

        <inertia
            ixx="0.00011"
            iyy="0.00013"
            izz="0.00020"
            ixy="0"
            ixz="0"
            iyz="0"/>

    </inertial>

</link>

<joint name="bottom_plate_to_battery_joint"
