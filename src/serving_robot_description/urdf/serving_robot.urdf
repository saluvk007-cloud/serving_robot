<!-- ===================================== -->
<!-- Top Plate                             -->
<!-- ===================================== -->

<link name="top_plate_link">

    <!-- Visual -->
    <visual>

        <geometry>
            <cylinder radius="0.16"
                      length="0.008"/>
        </geometry>

        <material name="blue">
            <color rgba="0.2 0.4 0.9 1"/>
        </material>

    </visual>

    <!-- Collision -->
    <collision>

        <geometry>
            <cylinder radius="0.16"
                      length="0.008"/>
        </geometry>

